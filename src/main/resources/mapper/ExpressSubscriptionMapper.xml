<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.douyin.shipping.mapper.ExpressSubscriptionMapper">

    <resultMap id="BaseResultMap" type="ExpressSubscription">
        <id column="id" property="id"/>
        <result column="express_id" property="expressId"/>
        <result column="logistic_code" property="logisticCode"/>
        <result column="shipper_code" property="shipperCode"/>
        <result column="callback_url" property="callbackUrl"/>
        <result column="subscription_status" property="subscriptionStatus"/>
        <result column="last_push_time" property="lastPushTime"/>
        <result column="push_success_count" property="pushSuccessCount"/>
        <result column="push_fail_count" property="pushFailCount"/>
        <result column="subscribe_time" property="subscribeTime"/>
        <result column="expire_time" property="expireTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, express_id, logistic_code, shipper_code, callback_url, subscription_status,
        last_push_time, push_success_count, push_fail_count, subscribe_time, expire_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO express_subscription (
            express_id, logistic_code, shipper_code, callback_url, subscription_status, expire_time
        ) VALUES (
            #{expressId}, #{logisticCode}, #{shipperCode}, #{callbackUrl}, #{subscriptionStatus}, #{expireTime}
        )
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription WHERE id = #{id}
    </select>

    <select id="findByExpressId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription WHERE express_id = #{expressId}
    </select>

    <select id="findByLogisticCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription WHERE logistic_code = #{logisticCode}
    </select>

    <select id="findBySubscriptionStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription WHERE subscription_status = #{subscriptionStatus}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription
    </select>

    <select id="findByExpireTimeBeforeAndSubscriptionStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM express_subscription 
        WHERE expire_time &lt; #{time} AND subscription_status = #{status}
    </select>

    <update id="updatePushStats">
        UPDATE express_subscription 
        SET last_push_time = #{pushTime},
            push_success_count = push_success_count + #{successCount},
            push_fail_count = push_fail_count + #{failCount}
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE express_subscription SET subscription_status = #{status} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM express_subscription WHERE id = #{id}
    </delete>

    <delete id="deleteByExpressId">
        DELETE FROM express_subscription WHERE express_id = #{expressId}
    </delete>

</mapper>
